# Copy this file to .env and paste your real keys there.
# You only need one working AI key, but more keys give better fallback.

GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional extra backups.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
OPENROUTER_API_KEY=
# Choose a current free OpenRouter model from https://openrouter.ai/models
# It usually ends with :free
OPENROUTER_MODEL=
PUBLIC_APP_URL=https://pdf-mock-emulator.onrender.com

# Optional local ports.
PORT=8080
BASE_PATH=/
API_URL=http://localhost:8080
